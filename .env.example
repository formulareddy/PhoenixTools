# =============================================================================
# PhoenixTools Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# AI API Keys (for chat + AI tools)
OPENCODE_API_KEY=
OPENROUTER_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Razorpay (LIVE MODE for production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google AdSense (get from https://adsense.google.com)
GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Ad Slot IDs (get from Google AdSense after creating ad units)
NEXT_PUBLIC_AD_SLOT_TOP=1234567890
NEXT_PUBLIC_AD_SLOT_MIDDLE=1234567891
NEXT_PUBLIC_AD_SLOT_BOTTOM=1234567892

# Web3Forms (for contact form — get key at https://web3forms.com, free 250/month)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
